{
    "env": {
        "browser": true,
        "es2021": true,
        "jquery": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
        "ecmaVersion": 2021,
        "sourceType": "script"
    },
    "rules": {
        "no-unused-vars": "warn",
        "no-console": "warn",
        "no-undef": "warn",
        "eqeqeq": "warn",
        "no-eval": "error",
        "no-implied-eval": "error"
    },
    "globals": {
        "wp": "readonly",
        "gc_chat_obj": "readonly",
        "gc_shop_url": "readonly",
        "ajaxurl": "readonly"
    }
}
